local BlackBoxUI = loadstring(game:HttpGet("https://raw.githubusercontent.com/onyxpotter/OnyxHub/refs/heads/main/ui"))()

local window = BlackBoxUI:CreateWindow({
    Title = "Ultimate Script 🔥",
    Name = "UltimateScript"
})

-- Tab 1: Combat
local combatTab = window:CreateTab({
    Name = "⚔️ Combat",
    Icon = "⚔️"
})

combatTab:CreateButton({
    Text = "Kill Aura",
    Callback = function()
        print("Kill Aura Activated!")
    end
})

local aimbotToggle = combatTab:CreateToggle({
    Text = "Aimbot",
    Callback = function(state)
        print("Aimbot:", state)
    end
})

local fovSlider = combatTab:CreateSlider({
    Text = "FOV",
    Min = 30,
    Max = 500,
    Default = 120,
    Callback = function(value)
        print("FOV:", value)
    end
})

local targetDropdown = combatTab:CreateDropdown({
    Text = "Target",
    Items = {"Players", "NPCs", "Mobs", "All"},
    Default = 1,
    Callback = function(item, index)
        print("Target:", item, "Index:", index)
    end
})

-- Tab 2: Movement
local movementTab = window:CreateTab({
    Name = "🏃 Movement",
    Icon = "🏃"
})

local speedSlider = movementTab:CreateSlider({
    Text = "Walk Speed",
    Min = 16,
    Max = 200,
    Default = 50,
    Callback = function(value)
        local player = game.Players.LocalPlayer
        if player.Character and player.Character:FindFirstChild("Humanoid") then
            player.Character.Humanoid.WalkSpeed = value
        end
    end
})

local flyToggle = movementTab:CreateToggle({
    Text = "Fly",
    Callback = function(state)
        print("Fly:", state)
    end
})

movementTab:CreateButton({
    Text = "Teleport to Spawn",
    Callback = function()
        print("Teleported!")
    end
})

-- Tab 3: Visuals
local visualsTab = window:CreateTab({
    Name = "👁️ Visuals",
    Icon = "👁️"
})

local espDropdown = visualsTab:CreateDropdown({
    Items = {"Box ESP", "Name ESP", "Tracer ESP", "Full ESP"},
    Callback = function(item)
        print("ESP Type:", item)
    end
})

-- Update slider programmatically
wait(2)
speedSlider.Set(100)
aimbotToggle.Toggle(true)
targetDropdown.Set(3)
