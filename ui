            tab.Content.Visible = true
            TweenService:Create(tabButton, TweenInfo.new(0.2), {
                TextColor3 = Themes.Dark.TextPrimary
            }):Play()
        end)
        
        tabButton.MouseEnter:Connect(function()
            if currentTab ~= tab then
                TweenService:Create(tabButton, TweenInfo.new(0.2), {
                    TextColor3 = Themes.Dark.Accent
                }):Play()
            end
        end)
        
        tabButton.MouseLeave:Connect(function()
            if currentTab ~= tab then
                TweenService:Create(tabButton, TweenInfo.new(0.2), {
                    TextColor3 = Themes.Dark.TextSecondary
                }):Play()
            end
        end)
        
        -- Select first tab
        if #tabs == 1 then
            tabButton.MouseButton1Click:Fire()
        end
        
        -- Element Methods
        function tab:CreateButton(options)
            options = options or {}
            local button = Instance.new("TextButton")
            button.Name = options.Name or "Button"
            button.Size = UDim2.new(1, 0, 0, 45)
            button.BackgroundColor3 = Themes.Dark.BgTertiary
            button.Text = options.Text or "Button"
            button.TextColor3 = Themes.Dark.TextPrimary
            button.TextScaled = true
            button.Font = Enum.Font.Gotham
            button.Parent = tab.Content
            
            createCorner(button, 12)
            createStroke(button, 1, Themes.Dark.Stroke)
            
            local hoverTween = TweenInfo.new(0.2, Enum.EasingStyle.Quart)
            
            button.MouseEnter:Connect(function()
                TweenService:Create(button, hoverTween, {
                    BackgroundColor3 = Themes.Dark.AccentHover,
                    TextColor3 = Color3.white
                }):Play()
            end)
            
            button.MouseLeave:Connect(function()
                TweenService:Create(button, hoverTween, {
                    BackgroundColor3 = Themes.Dark.BgTertiary,
                    TextColor3 = Themes.Dark.TextPrimary
