local Easing = {
    QuadOut = function(t) return 1 - (1 - t) * (1 - t) end,
    ExpoOut = function(t) return t == 1 and 1 or 1 - 2^(-10 * t) end
}

-- Helper Functions (tetap sama)
local function createCorner(parent, radius)
    local corner = Instance.new("UICorner")
    corner.CornerRadius = UDim.new(0, radius or 12)
    corner.Parent = parent
    return corner
end

local function createStroke(parent, thickness, color)
    local stroke = Instance.new("UIStroke")
    stroke.Thickness = thickness or 1
    stroke.Color = color or Color3.fromRGB(255, 255, 255)
    stroke.Parent = parent
    return stroke
end

local function createGradient(parent)
    local gradient = Instance.new("UIGradient")
    gradient.Rotation = 45
    gradient.Color = ColorSequence.new{
        ColorSequenceKeypoint.new(0, Color3.fromRGB(100, 150, 255)),
        ColorSequenceKeypoint.new(1, Color3.fromRGB(70, 130, 255))
    }
    gradient.Parent = parent
    return gradient
end

local function rippleEffect(parent)
    local ripple = Instance.new("Frame")
    ripple.Name = "Ripple"
    ripple.Size = UDim2.new(0, 0, 0, 0)
    ripple.Position = UDim2.new(0.5, 0, 0.5, 0)
    ripple.AnchorPoint = Vector2.new(0.5, 0.5)
    ripple.BackgroundTransparency = 0.7
    ripple.BackgroundColor3 = Color3.fromRGB(255, 255, 255)
    ripple.ZIndex = parent.ZIndex + 1
    createCorner(ripple, 999)
    ripple.Parent = parent
    
    local mouse = UserInputService:GetMouseLocation()
    ripple.Position = UDim2.new(0, mouse.X - parent.AbsolutePosition.X, 0, mouse.Y - parent.AbsolutePosition.Y)
    
    local size = parent.AbsoluteSize.X
    TweenService:Create(ripple, TweenInfo.new(0.4, Enum.EasingStyle.Quart, Enum.EasingDirection.Out), {
        Size = UDim2.new(0, size * 2, 0, size * 2),
        BackgroundTransparency = 1
    }):Play()
    
    game:GetService("Debris"):AddItem(ripple, 0.4)
end

