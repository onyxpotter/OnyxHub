--// BASE POSITION
local function getBasePosition()
    local bosses = workspace:FindFirstChild("Bosses")
    if not bosses then return nil end
    local base = bosses:FindFirstChild("base13")
    if not base then return nil end
    local root = base:FindFirstChild("HumanoidRootPart") or base:FindFirstChildWhichIsA("BasePart")
    return root and root.Position or nil
end

--// GET BEST BRAINROT
local function getBestBrainrot(basePos)
    local bestItem, bestScore = nil, -math.huge
    for _, folder in ipairs(folders) do
        if folder then
            for _, item in ipairs(folder:GetChildren()) do
                local part = item:IsA("BasePart") and item or item:FindFirstChildWhichIsA("BasePart")
                if part then
                    local dist = (part.Position - basePos).Magnitude
                    if dist <= CONFIG.StealRadius then
                        local bps = item:GetAttribute("BPS") or item:GetAttribute("PerSecond") or item:GetAttribute("Value") or item:GetAttribute("Rate") or 0
                        local score = (bps * 1000) - dist
                        if score > bestScore then
                            bestScore = score
                            bestItem = item
                        end
                    end
                end
            end
        end
    end
    return bestItem
end

--// STEAL SYSTEM
local detectedMode = nil
local function itemStillExists(item)
    return item and item.Parent ~= nil
end
local function trySteal(args, item)
    pcall(function()
        RemoteEvent:FireServer(unpack(args))
    end)
    task.wait(0.15)
    return not itemStillExists(item)
end
local function detectMode(item)
    local patterns = {{"Steal", item}, {"Collect", item}, {"PickUp", item}, {"Take", item}, {item}}
    for _, args in ipairs(patterns) do
        if trySteal(args, item) then
            print("[DETECTED MODE]:", args[1] or "Instance")
            return args
        end
    end
    return nil
end

local function triggerPrompt(item)
    local prompt = item:FindFirstChildWhichIsA("ProximityPrompt", true)
    if not prompt and item.Parent then
        prompt = item.Parent:FindFirstChildWhichIsA("ProximityPrompt", true)
    end
    if prompt then
        prompt.HoldDuration = 0
        fireproximityprompt(prompt)
        task.wait(CONFIG.StealDelay)
        return true
    end
    return false
end

local function stealItem(item)
    if not item then return false end
    local part = item:IsA("BasePart") and item or item:FindFirstChildWhichIsA("BasePart")
    if part then teleportTo(part.Position) end
    if triggerPrompt(item) then
        if not itemStillExists(item) then return true end
    end
    if not detectedMode then detectedMode = detectMode(item) end
    if not detectedMode then return false end
    local args = {}
    for i, v in ipairs(detectedMode) do
        args[i] = (typeof(v) == "Instance") and item or v
    end
    for _ = 1, 3 do
        if trySteal(args, item) then return true end
        task.wait(0.1)
    end
    detectedMode = nil
    return false
end

--// RUN BRAINROT CYCLE
local function runBrainrotCycle()
    local basePos = getBasePosition()
    if not basePos then return end
    teleportTo(basePos)
    for _ = 1, 15 do
        basePos = getBasePosition()
        if not basePos then break end
        local bestItem = getBestBrainrot(basePos)
        if not bestItem then break end
        local success = stealItem(bestItem)
        if success then break end
    end
    teleportTo(CONFIG.SpawnLocation or hrp.Position)
end

