local Rayfield = loadstring(game:HttpGet('https://sirius.menu/rayfield'))()

local Window = Rayfield:CreateWindow({
    Name = "Fishing Chef by ONYX HUB",
    LoadingTitle = "Fishing Chef",
    LoadingSubtitle = "by ONYX HUB",
    ConfigurationSaving = {
        Enabled = true,
        FolderName = "FishingChefHub",
        FileName = "AutoFishConfig"
    },
    Discord = { Enabled = false },
    KeySystem = false,
})

local MainTab = Window:CreateTab("Main", 4483362458)
local TeleportTab = Window:CreateTab("Teleport", 4483362458)

-- Variables
local AutoFishEnabled = false
local AutoSellEnabled = false

-- ==================== AUTO FISH (Combined) ====================
MainTab:CreateToggle({
    Name = "Auto Fish (Cast + Instant Catch)",
    CurrentValue = false,
    Flag = "AutoFishFlag",
    Callback = function(Value)
        AutoFishEnabled = Value
       
        while AutoFishEnabled do
            pcall(function()
                local castArgs = {1}
                game:GetService("ReplicatedStorage")
                    :WaitForChild("Packages")
                    :WaitForChild("Knit")
                    :WaitForChild("Services")
                    :WaitForChild("Fish")
                    :WaitForChild("RF")
                    :WaitForChild("CastRequest"):InvokeServer(unpack(castArgs))
            end)
           
            task.wait(0.0001)
           
            pcall(function()
                local catchArgs = {true}
                game:GetService("ReplicatedStorage")
                    :WaitForChild("Packages")
                    :WaitForChild("Knit")
                    :WaitForChild("Services")
                    :WaitForChild("Fish")
                    :WaitForChild("RF")
                    :WaitForChild("MinigameResolved"):InvokeServer(unpack(catchArgs))
            end)
           
            task.wait(0.001)
        end
    end,
})

-- ==================== AUTO SELL ====================
MainTab:CreateToggle({
    Name = "Auto Sell All Fish",
    CurrentValue = false,
    Flag = "AutoSellFlag",
    Callback = function(Value)
        AutoSellEnabled = Value
        while AutoSellEnabled do
            pcall(function()
                game:GetService("ReplicatedStorage")
                    :WaitForChild("Packages")
                    :WaitForChild("Knit")
                    :WaitForChild("Services")
                    :WaitForChild("Fish")
                    :WaitForChild("RE")
                    :WaitForChild("SellFish"):FireServer()
            end)
            task.wait(4)
        end
    end,
})

-- ==================== TELEPORT DROPDOWN ====================
TeleportTab:CreateDropdown({
    Name = "Teleport to Zone",
    Options = {"Koi Pond", "Bamboo Forest", "Razor Reef"},
    CurrentOption = {""},
    MultipleOptions = false,
    Flag = "ZoneTeleport",
    Callback = function(Option)
        local zoneName = Option[1]
        if not zoneName or zoneName == "" then return end
        
        local targetCFrame = nil
        local player = game.Players.LocalPlayer
        local character = player.Character or player.CharacterAdded:Wait()
        local root = character:FindFirstChild("HumanoidRootPart")
        
        if not root then
            Rayfield:Notify({Title = "Error", Content = "HumanoidRootPart tidak ditemukan!", Duration = 3})
            return
        end

        pcall(function()
            if zoneName == "Koi Pond" then
                local model = workspace.Map.Areas.KoiPond.Model.WoodenBridge.Model.Model
                local children = model:GetChildren()
                if children[37] then
                    targetCFrame = children[37].CFrame
                end

            elseif zoneName == "Bamboo Forest" then
                local model = workspace.Map.Areas.BambooForest.Model
                local children = model:GetChildren()
                if children[572] then
                    targetCFrame = children[572].CFrame
                end

            elseif zoneName == "Razor Reef" then
                local landZone = workspace.Map.RazorReef.LandZone:GetChildren()[43]
                local targetPart = landZone:GetChildren()[2]
                if targetPart then
                    targetCFrame = targetPart.CFrame
                end
            end
        end)

        if targetCFrame then
            root.CFrame = targetCFrame * CFrame.new(0, 6, 0)
            Rayfield:Notify({
                Title = "Teleport Berhasil",
                Content = "Telah teleport ke " .. zoneName,
                Duration = 3,
            })
        else
            Rayfield:Notify({
                Title = "Teleport Gagal",
                Content = "Lokasi " .. zoneName .. " tidak ditemukan atau berubah.",
                Duration = 4,
            })
        end
    end,
})

Rayfield:Notify({
    Title = "Script Loaded",
    Content = "Fishing Chef Auto Fish is ready!",
    Duration = 6,
})
